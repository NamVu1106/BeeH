    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "java",
            "name": "Spring Boot-PolydatnApplication<polydatn>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.beearena.PolydatnApplication",
            "projectName": "polydatn",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot-PolydatnApplication<polydatn>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.example.polydatn.PolydatnApplication",
            "projectName": "polydatn",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}